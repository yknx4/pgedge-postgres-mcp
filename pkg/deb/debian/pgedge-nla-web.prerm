#!/bin/sh
set -e

case "$1" in
    remove|deconfigure)
        # Remove nginx site symlink
        rm -f /etc/nginx/sites-enabled/pgedge-nla-web
        
        # Reload nginx
        if [ -x /usr/sbin/nginx ]; then
            systemctl reload nginx >/dev/null 2>&1 || true
        fi
        ;;
esac

#DEBHELPER#

exit 0
